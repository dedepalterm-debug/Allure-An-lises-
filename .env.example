# ---- Supabase (opcional na v1) ----
# Sem estas variáveis, o histórico usa localStorage como fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Anthropic (análise qualitativa por IA) ----
# A chave NUNCA é exposta ao cliente; usada apenas na API route /api/ai.
ANTHROPIC_API_KEY=
# Modelo Claude usado na análise qualitativa.
ANTHROPIC_MODEL=claude-sonnet-4-6
